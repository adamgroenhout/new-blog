---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<header>
	<nav>
		<h2><a href={baseUrl + '/'}>{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href={baseUrl + '/'}>Home</HeaderLink>
			<HeaderLink href={baseUrl + '/blog'}>Blog</HeaderLink>
			<HeaderLink href={baseUrl + '/contact'}>Contact</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		margin: 0;
		padding: 0;
		background: rgba(252, 248, 241, 0.8);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		border-bottom: 1px solid rgba(var(--gray-light), 0.5);
	}
	h2 {
		margin: 0;
		font-size: 2em;
	}
	nav {
		width: 920px;
		max-width: calc(100% - 2em);
		margin: auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.5em 1em;
		flex-wrap: wrap;
	}
	.internal-links {
		display: flex;
		justify-content: flex-end;
		flex-grow: 1;
		gap: 0.5em;
		flex-wrap: wrap;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	h2 a {
		padding-left: 0;
	}
	.internal-links a:last-child {
		padding-right: 0;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
</style>
